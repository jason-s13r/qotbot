# Telegram Bot Configuration
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_OWNER=

# LLM Configuration (Ollama)
LLM_API_URL=http://localhost:3000
LLM_API_KEY=
LLM_MODEL=qwen3.5:4b
LLM_CLASSIFIER_MODEL=qwen3.5:0.8b

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
DATA_PATH=/app/data

# Bot Behavior
DEBOUNCE_MS=14000
SESSION_TIMEOUT_MINUTES=10
HISTORY_WINDOW=50

# Bot Identity (optional - defaults extracted from Telegram bot profile)
# Comma-separated list of names the bot will respond to
BOT_NAMES=bot,assistant

# Response Mode: active (responds when mentioned), passive (only commands), random (random chance)
RESPONSE_MODE=active

# Random response chance (0.0-1.0) - only used when RESPONSE_MODE=random
RANDOM_RESPONSE_CHANCE=0.0

# Default permission level for new chats: none, command, full
DEFAULT_PERMISSION=none

# Enable memory system: true or false
ENABLE_MEMORY=true

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: Admin Commands
# TELEGRAM_BOT_OWNER should be set to your Telegram user ID

# Notes:
# - Get TELEGRAM_API_ID and TELEGRAM_API_HASH from https://my.telegram.org
# - Get TELEGRAM_BOT_TOKEN from @BotFather on Telegram
# - TELEGRAM_BOT_OWNER is your Telegram user ID (use @userinfobot to find it)
# - LLM_API_URL should point to your Open WebUI instance
#   - On Mac: use host.docker.internal
#   - On Linux: use your host IP or run with --network host
# - LLM_CLASSIFIER_MODEL is used for relevance classification (lightweight model)
# - LLM_MODEL is used for main conversation (can be larger model)
