# Telegram Bot Configuration
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_OWNER=

# Bot Settings
BOT_NAME=qotbot

# LLM Configuration
LLM_API_URL=http://localhost:11434
LLM_API_KEY=
LLM_CHAT_MODEL=qwen3.5:4b
LLM_CLASSIFIER_MODEL=qwen3.5:4b
LLM_SUMMARY_MODEL=qwen3.5:4b
LLM_VISION_MODEL=qwen3.5:4b

# Whisper Configuration
WHISPER_MODEL=turbo
WHISPER_LANGUAGE=

# External APIs (required for respective tools)
# OLLAMA_API_KEY=       # Required for Ollama Cloud use of web search & web fetch tools
# WOLFRAM_APPID=        # Required for Wolfram Alpha tool

# HTTP Timeout (seconds)
WEB_TIMEOUT=20

# Audio Transcription
MAX_TRANSCRIPT_DURATION=300

# Data Storage
DATA_PATH=./data
